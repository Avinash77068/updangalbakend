{
  "openapi": "3.0.0",
  "info": {
    "title": "UpDangal CMS API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:4000/api/v1"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "API is healthy"
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "summary": "Login and receive access/refresh tokens",
        "responses": {
          "200": {
            "description": "Authenticated"
          }
        }
      }
    },
    "/news": {
      "get": {
        "summary": "List published articles with pagination, filters, sorting"
      },
      "post": {
        "summary": "Create article draft/published content"
      }
    },
    "/categories": {
      "get": {
        "summary": "List categories"
      }
    },
    "/ads": {
      "get": {
        "summary": "List ads by placement/type"
      }
    },
    "/videos": {
      "get": {
        "summary": "List videos or shorts"
      }
    },
    "/trending": {
      "get": {
        "summary": "List trending topics"
      }
    },
    "/search": {
      "get": {
        "summary": "Search content across modules"
      }
    },
    "/analytics/dashboard": {
      "get": {
        "summary": "CMS dashboard metrics"
      }
    }
  }
}
